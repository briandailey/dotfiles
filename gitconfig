[user]
	name = Brian Dailey
	email = brian@dailytechnology.net
	signingKey = 09AA8EF8E38415F2
[color]
	status = auto
	diff = auto
[merge]
    conflictStyle = zdiff3
[alias]
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%ad)%Creset %Cblue(%an)%Creset' --abbrev-commit --date=relative
	co = checkout
	ci = commit -S
	st = status -s
	wf = diff --color-words
	up = "!git remote update -p; git merge --ff-only @{u}"
    mm = "!git merge master -m\"Merge master into \"`git rev-parse --abbrev-ref HEAD`"
[core]
	editor = /usr/bin/vim
    pager = delta
[github]
	user = briandailey
[push]
	default = simple
[gpg]
    # macos
    # program = /opt/homebrew/bin/gpg
    # ubuntu
    program = /usr/bin/gpg
[commit]
	gpgsign = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
